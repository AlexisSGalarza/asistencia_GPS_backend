# ──────────────────────────────────────────────────────────────────────────────
# claves.env.example  –  Copia este archivo como "claves.env" y rellena los valores
# NUNCA subas claves.env a git (ya está en .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
# Genera una clave con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-segura

# True en desarrollo local, False en producción (Railway lo setea automático)
DEBUG=True

# En desarrollo puedes dejar el asterisco. En producción pon tu dominio.
ALLOWED_HOSTS=*

# ── Base de datos (desarrollo local) ──────────────────────────────────────────
DB_NAME=asistencia_gps
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_HOST=localhost
DB_PORT=5432

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Crea una "Contraseña de aplicación" en: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=tucorreo@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password_aqui

# ── CORS (producción) ─────────────────────────────────────────────────────────
# Solo necesario cuando DEBUG=False. Pon la URL de tu frontend.
# CORS_ALLOWED_ORIGINS=https://tu-frontend.railway.app,https://otro-origen.com
